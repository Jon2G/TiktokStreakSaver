<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TiktokStreakSaver.Views.TutorialMediaView"
             x:Name="Root">
    <Border StrokeThickness="1"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
            StrokeShape="RoundRectangle 16"
            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
            Padding="0">
        <Grid>
            <Image x:Name="MediaImage"
                   Aspect="AspectFit"
                   IsVisible="False" />
            <WebView x:Name="MediaWebView"
                     IsVisible="False"
                     BackgroundColor="Transparent"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />
            <VerticalStackLayout x:Name="PlaceholderLayout"
                                 Padding="20"
                                 Spacing="8"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center">
                <Label Text="📱"
                       FontSize="40"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="PlaceholderTitleLabel"
                       Text="Add a screenshot, GIF, or video"
                       FontFamily="InterSemiBold"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                <Label x:Name="PlaceholderHintLabel"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
