<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TiktokStreakSaver.AboutPopupPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
             Shell.PresentationMode="ModalAnimated">

    <Grid RowDefinitions="Auto, *, Auto" Padding="24" RowSpacing="24">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" HorizontalOptions="Center" Margin="0, 16, 0, 0">
            <Label x:Name="HeaderTitle" 
                   Text="Welcome to Streak Saver" 
                   Style="{StaticResource PageTitleLabel}" 
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Label x:Name="VersionLabel" 
                   Text="v1.0.0" 
                   Style="{StaticResource DataLabel}" 
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Label x:Name="SubHeaderLabel" 
                   Text="Keep your streaks alive, automatically." 
                   Style="{StaticResource DataLabel}" 
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Scrollable content area -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="24">
                
                <Border Style="{StaticResource SectionCard}" 
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                        StrokeThickness="0"
                        Padding="0"
                        x:Name="ChangelogBorder">
                    <WebView x:Name="ChangelogWebView"
                             HeightRequest="300"
                             BackgroundColor="Transparent"
                             VerticalOptions="FillAndExpand"/>
                </Border>

                <!-- App Information -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="About this app" Style="{StaticResource SectionLabel}"/>
                    <Label Text="Streak Saver is designed to automate and protect your TikTok streaks. It runs natively in the background on a schedule you configure, finding and messaging your friends so you are less likely to miss a day." 
                           Style="{StaticResource ValueLabel}" 
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>

                <!-- Project & author -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Open source" Style="{StaticResource SectionLabel}" Margin="0, 0, 0, 4"/>
                    <Label Text="Streak Saver by Jon2G" Style="{StaticResource ValueLabel}"/>
                    <Label Text="https://github.com/Jon2G/TiktokStreakSaver"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                           FontSize="12" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Credits" Style="{StaticResource SectionLabel}" Margin="0, 8, 0, 4"/>
                    <Label Style="{StaticResource ValueLabel}" LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Automation patterns and burst-mode ideas are aligned with the open-source Feener project (" />
                                <Span Text="streak-tiktok"
                                      TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                      TextDecorations="Underline">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFeenerCreditTapped" />
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=") by eulfen and contributors." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <!-- Data & Permissions Notice -->
                <VerticalStackLayout Spacing="8" Margin="0, 0, 0, 12">
                    <Label Text="Privacy &amp; System Permissions" 
                           Style="{StaticResource SectionLabel}" 
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" 
                           FontSize="12"/>
                    <Label Text="All operations execute locally on your device. Zero credentials or messaging session keys are extracted or broadcasted remotely. Background automations require battery exemptions and exact-alarm scheduling to function reliably." 
                           Style="{StaticResource DataLabel}" 
                           LineBreakMode="WordWrap" 
                           FontSize="12"/>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky Footer -->
        <VerticalStackLayout Grid.Row="2" Spacing="8">

            <!-- Download progress — hidden unless download is active -->
            <Label x:Name="ProgressLabel"
                   IsVisible="False"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   FontSize="13"/>

            <!-- Update buttons: Install + Later (shown only for update popups) -->
            <Grid x:Name="UpdateButtonGrid"
                  ColumnDefinitions="*, 12, *"
                  IsVisible="False">
                <Button x:Name="LaterButton"
                        Grid.Column="0"
                        Text="Later"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}"
                        CornerRadius="12"
                        HeightRequest="56"
                        Clicked="OnLaterClicked"/>
                <Button x:Name="InstallButton"
                        Grid.Column="2"
                        Text="Install"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                        FontFamily="InterSemiBold"
                        CornerRadius="12"
                        HeightRequest="56"
                        Clicked="OnInstallClicked"/>
            </Grid>

            <!-- Continue button: shown only for onboarding (non-update) popups -->
            <Button x:Name="CloseButton"
                    Text="Continue"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                    FontFamily="InterSemiBold"
                    CornerRadius="12"
                    HeightRequest="56"
                    Clicked="OnCloseClicked"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
